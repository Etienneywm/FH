{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/sitemap.xml",
      "destination": "https://www.performancefondamentale.com/sitemap.xml",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/breathwork", "destination": "/breathwork.html" },
    { "source": "/mentions-legales", "destination": "/mentions-legales.html" },
    { "source": "/tarifs", "destination": "/tarifs.html" },
    { "source": "/a-propos", "destination": "/a-propos.html" }
    { "source": "/blog", "destination": "/blog.html" }
  ]
}
